# ─── Copy this file to .env.local and fill in real values ───────────────
# Never commit .env or .env.local (they are in .gitignore).
# This file (.env.example) is SAFE to commit — use placeholders only, no real keys.

# Local: use `npm run dev:vercel` or `vercel dev` so /api/contact works.

# Resend — https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Verified sender (test: onboarding@resend.dev) or your verified domain
RESEND_FROM="Mac Auto Services <onboarding@resend.dev>"

# Where enquiries are sent
NOTIFICATION_EMAIL=you@example.com

# Optional: link in customer confirmation email
SITE_URL=https://www.macautoservices.co.nz

# Optional: only if API is not same-origin (e.g. custom backend URL)
# VITE_CONTACT_API_URL=http://localhost:3000/api/contact
